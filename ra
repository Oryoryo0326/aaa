<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>美少女ガチャゲーム</title>
<style>
  body {
    margin: 0;
    font-family: sans-serif;
    background: radial-gradient(circle, #1a1a2e, #000);
    color: white;
    text-align: center;
  }

  h1 {
    margin-top: 20px;
    color: #ffb6c1;
    text-shadow: 0 0 10px #ff69b4;
  }

  .gacha-box {
    margin: 30px auto;
    padding: 20px;
    width: 320px;
    border-radius: 20px;
    background: #111;
    box-shadow: 0 0 20px rgba(255,182,193,0.4);
  }

  button {
    padding: 12px 25px;
    font-size: 18px;
    border: none;
    border-radius: 10px;
    background: linear-gradient(45deg, #ff69b4, #ffb6c1);
    cursor: pointer;
  }

  button:hover {
    opacity: 0.8;
  }

  .result {
    margin-top: 20px;
    font-size: 20px;
    min-height: 50px;
  }

  img {
    margin-top: 15px;
    width: 200px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(255,255,255,0.3);
  }

  .rarity-SSR { color: gold; text-shadow: 0 0 10px gold; }
  .rarity-SR { color: violet; }
  .rarity-R { color: skyblue; }
  .rarity-N { color: gray; }
</style>
</head>
<body>

<h1>✨ 美少女ガチャ ✨</h1>

<div class="gacha-box">
  <button onclick="drawGacha()">ガチャを引く！</button>
  <div id="result" class="result">ここに結果が出る</div>
  <img id="charImage" src="" style="display:none;">
</div>

<script>
const characters = [
  { name: "SSR：伝説のアイドル", rarity: "SSR", img: "https://placekitten.com/200/200" },
  { name: "SR：魔法少女", rarity: "SR", img: "https://placebear.com/200/200" },
  { name: "R：元気な女の子", rarity: "R", img: "https://placekitten.com/201/200" },
  { name: "N：普通の女の子", rarity: "N", img: "https://placekitten.com/200/201" }
];

function drawGacha() {
  const rand = Math.random();
  let selected;

  if (rand < 0.05) {
    selected = characters[0];
  } else if (rand < 0.20) {
    selected = characters[1];
  } else if (rand < 0.50) {
    selected = characters[2];
  } else {
    selected = characters[3];
  }

  const resultDiv = document.getElementById("result");
  resultDiv.className = "result rarity-" + selected.rarity;
  resultDiv.textContent = selected.name;

  const img = document.getElementById("charImage");
  img.src = selected.img;
  img.style.display = "block";
}
</script>

</body>
</html>
